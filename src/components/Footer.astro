---
import { site, footerNav, socials, contact, attributions } from "@/config/site";

const year = new Date().getFullYear();
const socialLinks = [
  { name: "GitHub", href: socials.github, icon: "/icons/github.svg" },
  { name: "Twitter", href: socials.twitter, icon: "/icons/twitter.svg" },
  { name: "Facebook", href: socials.facebook, icon: "/icons/facebook.svg" },
  { name: "LinkedIn", href: socials.linkedin, icon: "/icons/linkedin.svg" },
];
---

<footer class="bg-brand text-white">
  <div class="mx-auto w-full max-w-[1280px] px-[5%] py-16 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">
      <!-- Brand + mission -->
      <div>
        <a href="/" class="inline-flex items-center" aria-label="Open Knowledge Belgium home">
          <img src="/logo/okbe-withname.svg" alt={site.name} class="h-11 w-auto brightness-0 invert" />
        </a>
        <p class="mt-5 max-w-[24rem] text-regular text-white/70">
          {site.tagline}. An umbrella organisation for open knowledge initiatives in Belgium.
        </p>
        <div class="mt-6 flex gap-3">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="flex size-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-electric"
            >
              <img src={s.icon} alt="" class="size-4 brightness-0 invert" />
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <div>
        <h3 class="text-small font-semibold uppercase tracking-wide text-white/50">Explore</h3>
        <ul class="mt-4 space-y-3">
          {footerNav.map((item) => (
            <li>
              <a href={item.to} class="text-regular text-white/80 transition-colors hover:text-white">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-small font-semibold uppercase tracking-wide text-white/50">Contact</h3>
        <address class="mt-4 space-y-1 text-regular not-italic text-white/80">
          {contact.lines.map((line) => <p>{line}</p>)}
          <p class="pt-2">
            <a href={`mailto:${contact.email}`} class="text-white underline-offset-4 hover:underline">
              {contact.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-white/10 pt-8 text-small text-white/50 md:flex-row md:items-center md:justify-between">
      <p>© {year} {site.name}. {attributions}</p>
      <a
        href="https://github.com/openknowledgebe/website"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-white"
      >
        Source on GitHub
      </a>
    </div>
  </div>
</footer>
