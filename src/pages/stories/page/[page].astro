---
import PageLayout from "@/layouts/PageLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { StoriesGrid } from "@/components/react/StoriesGrid";
import { getSortedStories, toStoryCard, STORIES_PER_PAGE } from "@/lib/content";

export async function getStaticPaths() {
  const all = await getSortedStories();
  const totalPages = Math.ceil(all.length / STORIES_PER_PAGE);
  const paths = [];
  for (let p = 2; p <= totalPages; p++) {
    paths.push({
      params: { page: String(p) },
      props: {
        pageNum: p,
        totalPages,
        cards: all.slice((p - 1) * STORIES_PER_PAGE, p * STORIES_PER_PAGE).map(toStoryCard),
      },
    });
  }
  return paths;
}

const { pageNum, totalPages, cards } = Astro.props;
const prev = pageNum - 1 === 1 ? "/stories" : `/stories/page/${pageNum - 1}`;
const next = pageNum < totalPages ? `/stories/page/${pageNum + 1}` : null;
---

<PageLayout
  title={`Stories · Page ${pageNum} · Open Knowledge Belgium`}
  description="News, updates and reflections from the Open Knowledge Belgium community."
>
  <PageHeader eyebrow={`Stories · Page ${pageNum} of ${totalPages}`} title="News from the open community" />

  <section class="px-[5%] py-16 md:py-24">
    <div class="mx-auto w-full max-w-[1280px]">
      <StoriesGrid client:visible items={cards} />

      <nav class="mt-14 flex items-center justify-center gap-3" aria-label="Pagination">
        <a
          href={prev}
          class="rounded-button border border-neutral-light px-5 py-2.5 text-small font-semibold text-neutral-darkest transition-colors hover:border-electric hover:text-electric"
        >
          ← Newer
        </a>
        <span class="rounded-button bg-brand px-5 py-2.5 text-small font-semibold text-white">
          {pageNum} / {totalPages}
        </span>
        {next && (
          <a
            href={next}
            class="rounded-button border border-neutral-light px-5 py-2.5 text-small font-semibold text-neutral-darkest transition-colors hover:border-electric hover:text-electric"
          >
            Older →
          </a>
        )}
      </nav>
    </div>
  </section>
</PageLayout>
